<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>#import("title") — Market Data</title>
    #clerkScript()
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css?v=2">
</head>
<body>
<script>
document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.clerk-signed-in')
        .forEach(function (el) { el.style.display = 'none'; });
});
</script>
<header>
    <a class="logo" href="/">MarketData</a>
    <div class="header-right">
        <div class="clerk-signed-in">
            <nav>
                <div class="nav-dropdown">
                    <button class="nav-dropdown-btn #import("nav_data_active")">Data ▾</button>
                    <div class="nav-dropdown-menu">
                        <a href="/exchanges"         class="#import("nav_exchanges")"        >Exchanges</a>
                        <a href="/currencies"        class="#import("nav_currencies")"       >Currencies</a>
                        <a href="/instruments"       class="#import("nav_instruments")"      >Instruments</a>
                        <a href="/equities"          class="#import("nav_equities")"         >Equities</a>
                        <a href="/indexes"           class="#import("nav_indexes")"          >Indexes</a>
                        <a href="/option-contracts"  class="#import("nav_option_contracts")" >Options</a>
                        <a href="/eod-prices"        class="#import("nav_eod_prices")"       >EOD Prices</a>
                        <a href="/option-eod-prices" class="#import("nav_option_eod")"       >Option Prices</a>
                        <a href="/corporate-actions" class="#import("nav_corp_actions")"     >Corp Actions</a>
                        <a href="/fred-yields"       class="#import("nav_fred_yields")"      >FRED Yields</a>
                        <a href="/market-holidays"   class="#import("nav_market_holidays")"  >Market Holidays</a>
                    </div>
                </div>
            </nav>
        </div>
        <div class="clerk-signed-in">
            <div id="clerk-user-button-nav"></div>
        </div>
    </div>
</header>
<main>
    #import("body")
</main>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.nav-dropdown-btn').forEach(function (btn) {
            btn.addEventListener('click', function (e) {
                e.stopPropagation();
                var dd = btn.closest('.nav-dropdown');
                dd.classList.toggle('open');
            });
        });
        document.addEventListener('click', function () {
            document.querySelectorAll('.nav-dropdown.open').forEach(function (dd) {
                dd.classList.remove('open');
            });
        });
    });
</script>
<script>
    function showEdit(id) {
        document.getElementById('row-' + id).style.display = 'none';
        document.getElementById('edit-' + id).style.display = 'table-row';
        const first = document.querySelector('#edit-' + id + ' .edit-input, #edit-' + id + ' .edit-select');
        if (first) first.focus();
    }
    function hideEdit(id) {
        document.getElementById('edit-' + id).style.display = 'none';
        document.getElementById('row-' + id).style.display = 'table-row';
    }
</script>
<script>
(async function () {
    await new Promise(function (resolve) {
        if (window.Clerk) { resolve(); return; }
        var t = setInterval(function () { if (window.Clerk) { clearInterval(t); resolve(); } }, 50);
    });
    await window.Clerk.load();
    if (window.Clerk.user) {
        document.querySelectorAll('.clerk-signed-in')
            .forEach(function (el) { el.style.display = ''; });
        var navBtn = document.getElementById('clerk-user-button-nav');
        if (navBtn) { window.Clerk.mountUserButton(navBtn); }
    }
})();
</script>
</body>
</html>
