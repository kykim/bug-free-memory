<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>#import("title") — Market Data</title>
    #clerkScript()
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --bg:        #0a0c0f;
            --surface:   #111318;
            --border:    #1e2229;
            --border-hi: #2e3340;
            --text:      #e2e6ed;
            --muted:     #5a6172;
            --accent:    #00d4aa;
            --accent-dim:#004d3e;
            --danger:    #ff4d6a;
            --danger-dim:#3d0014;
            --mono:      'IBM Plex Mono', monospace;
            --sans:      'IBM Plex Sans', sans-serif;
        }
        body { background: var(--bg); color: var(--text); font-family: var(--sans); font-size: 14px; min-height: 100vh; }
        header { border-bottom: 1px solid var(--border); padding: 0 40px; height: 56px; display: flex; align-items: center; justify-content: space-between; background: var(--surface); }
        .logo { font-family: var(--mono); font-size: 11px; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); text-decoration: none; }
        .header-right { display: flex; align-items: center; gap: 16px; }
        #clerk-user-button-nav { display: flex; align-items: center; }
        nav { display: flex; gap: 2px; }
        nav a { font-family: var(--mono); font-size: 11px; color: var(--muted); text-decoration: none; padding: 6px 12px; border-radius: 4px; letter-spacing: 0.06em; transition: color 0.15s, background 0.15s; }
        nav a:hover { color: var(--text); background: var(--border); }
        nav a.active { color: var(--accent); background: var(--accent-dim); }
        main { max-width: 1100px; margin: 0 auto; padding: 40px 40px 80px; }
        .page-header { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 32px; padding-bottom: 20px; border-bottom: 1px solid var(--border); }
        .page-title { font-family: var(--mono); font-size: 22px; font-weight: 600; letter-spacing: -0.02em; }
        .page-title small { display: block; font-size: 11px; font-weight: 400; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 4px; }
        .row-count { font-family: var(--mono); font-size: 11px; color: var(--muted); letter-spacing: 0.06em; }
        .row-count strong { color: var(--accent); }
        .flash { padding: 12px 16px; border-radius: 4px; font-family: var(--mono); font-size: 12px; margin-bottom: 24px; display: flex; align-items: center; gap: 10px; animation: fadeIn 0.25s ease; }
        .flash.success { background: var(--accent-dim); border: 1px solid var(--accent); color: var(--accent); }
        .flash.error   { background: var(--danger-dim); border: 1px solid var(--danger); color: var(--danger); }
        .flash.success::before { content: "✓"; font-size: 14px; }
        .flash.error::before   { content: "✕"; font-size: 14px; }
        .insert-panel { background: var(--surface); border: 1px solid var(--border); border-radius: 6px; padding: 24px; margin-bottom: 32px; }
        .panel-label { font-family: var(--mono); font-size: 10px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); margin-bottom: 16px; }
        .form-row { display: flex; gap: 12px; align-items: flex-end; flex-wrap: wrap; }
        .form-group { display: flex; flex-direction: column; gap: 6px; }
        .form-group label { font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); }
        .form-group input, .form-group select { background: var(--bg); border: 1px solid var(--border-hi); border-radius: 4px; color: var(--text); font-family: var(--mono); font-size: 13px; padding: 8px 12px; outline: none; transition: border-color 0.15s; }
        .form-group input:focus, .form-group select:focus { border-color: var(--accent); }
        .form-group input::placeholder { color: var(--muted); }
        .form-group select option { background: var(--surface); }
        .fg-sm  { width: 100px; }
        .fg-md  { width: 160px; }
        .fg-lg  { width: 240px; }
        .fg-xl  { flex: 1; min-width: 180px; }
        .btn { font-family: var(--mono); font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; border: none; border-radius: 4px; padding: 9px 18px; cursor: pointer; transition: opacity 0.15s, transform 0.1s; white-space: nowrap; }
        .btn:hover  { opacity: 0.85; }
        .btn:active { transform: scale(0.97); }
        .btn-primary { background: var(--accent); color: #000; }
        .btn-ghost   { background: transparent; border: 1px solid var(--border-hi); color: var(--muted); }
        .btn-ghost:hover { border-color: var(--text); color: var(--text); opacity: 1; }
        .btn-danger  { background: var(--danger-dim); border: 1px solid var(--danger); color: var(--danger); }
        .table-wrap { border: 1px solid var(--border); border-radius: 6px; overflow: hidden; overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; }
        thead tr { background: var(--surface); border-bottom: 1px solid var(--border-hi); }
        th { font-family: var(--mono); font-size: 10px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); padding: 12px 16px; text-align: left; white-space: nowrap; }
        tbody tr { border-bottom: 1px solid var(--border); transition: background 0.1s; }
        tbody tr:last-child { border-bottom: none; }
        tbody tr:hover { background: var(--surface); }
        td { padding: 12px 16px; vertical-align: middle; }
        .td-mono { font-family: var(--mono); font-size: 12px; }
        .td-accent { font-family: var(--mono); font-size: 13px; font-weight: 600; color: var(--accent); }
        .td-muted { color: var(--muted); font-size: 12px; }
        .td-actions { width: 160px; text-align: right; }
        .action-group { display: flex; gap: 8px; justify-content: flex-end; }
        .badge { display: inline-block; font-family: var(--mono); font-size: 10px; font-weight: 600; letter-spacing: 0.08em; padding: 3px 8px; border-radius: 3px; text-transform: uppercase; }
        .badge-call    { background: #002a1f; color: #00d4aa; border: 1px solid #00d4aa44; }
        .badge-put     { background: #2a0010; color: #ff4d6a; border: 1px solid #ff4d6a44; }
        .badge-active  { background: var(--accent-dim); color: var(--accent); border: 1px solid #00d4aa44; }
        .badge-inactive{ background: #1a1c22; color: var(--muted); border: 1px solid var(--border-hi); }
        .edit-row td { padding: 8px 16px; background: #0d1219; }
        .edit-form-row { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
        .edit-input { background: var(--bg); border: 1px solid var(--accent); border-radius: 4px; color: var(--text); font-family: var(--mono); font-size: 13px; padding: 7px 10px; outline: none; }
        .edit-select { background: var(--bg); border: 1px solid var(--accent); border-radius: 4px; color: var(--text); font-family: var(--mono); font-size: 13px; padding: 7px 10px; outline: none; }
        .edit-input-sm { width: 90px; }
        .edit-input-md { width: 150px; }
        .edit-input-lg { width: 220px; }
        .edit-input-xl { flex: 1; min-width: 160px; }
        .empty { padding: 48px 16px; text-align: center; font-family: var(--mono); font-size: 12px; color: var(--muted); letter-spacing: 0.06em; }
        .checkbox-group { display: flex; align-items: center; gap: 8px; padding-bottom: 2px; }
        .checkbox-group input[type=checkbox] { width: 16px; height: 16px; accent-color: var(--accent); cursor: pointer; }
        .checkbox-group label { font-family: var(--mono); font-size: 11px; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>
<script>
document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.clerk-signed-in')
        .forEach(function (el) { el.style.display = 'none'; });
});
</script>
<header>
    <a class="logo" href="/">MarketData</a>
    <div class="header-right">
        <div class="clerk-signed-in">
            <nav>
                <a href="/exchanges"         class="#import("nav_exchanges")"        >Exchanges</a>
                <a href="/currencies"        class="#import("nav_currencies")"       >Currencies</a>
                <a href="/instruments"       class="#import("nav_instruments")"      >Instruments</a>
                <a href="/equities"          class="#import("nav_equities")"         >Equities</a>
                <a href="/indexes"           class="#import("nav_indexes")"          >Indexes</a>
                <a href="/option-contracts"  class="#import("nav_option_contracts")" >Options</a>
                <a href="/eod-prices"        class="#import("nav_eod_prices")"       >EOD Prices</a>
                <a href="/option-eod-prices" class="#import("nav_option_eod")"       >Option Prices</a>
                <a href="/corporate-actions" class="#import("nav_corp_actions")"     >Corp Actions</a>
            </nav>
        </div>
        <div class="clerk-signed-in">
            <div id="clerk-user-button-nav"></div>
        </div>
    </div>
</header>
<main>
    #import("body")
</main>
<script>
    function showEdit(id) {
        document.getElementById('row-' + id).style.display = 'none';
        document.getElementById('edit-' + id).style.display = 'table-row';
        const first = document.querySelector('#edit-' + id + ' .edit-input, #edit-' + id + ' .edit-select');
        if (first) first.focus();
    }
    function hideEdit(id) {
        document.getElementById('edit-' + id).style.display = 'none';
        document.getElementById('row-' + id).style.display = 'table-row';
    }
</script>
<script>
(async function () {
    await new Promise(function (resolve) {
        if (window.Clerk) { resolve(); return; }
        var t = setInterval(function () { if (window.Clerk) { clearInterval(t); resolve(); } }, 50);
    });
    await window.Clerk.load();
    if (window.Clerk.user) {
        document.querySelectorAll('.clerk-signed-in')
            .forEach(function (el) { el.style.display = ''; });
        var navBtn = document.getElementById('clerk-user-button-nav');
        if (navBtn) { window.Clerk.mountUserButton(navBtn); }
    }
})();
</script>
</body>
</html>
