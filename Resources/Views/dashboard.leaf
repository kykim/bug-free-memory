<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard — Market Data</title>
    #clerkScript()
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --bg:        #0a0c0f;
            --surface:   #111318;
            --border:    #1e2229;
            --border-hi: #2e3340;
            --text:      #e2e6ed;
            --muted:     #5a6172;
            --accent:    #00d4aa;
            --accent-dim:#004d3e;
            --danger:    #ff4d6a;
            --danger-dim:#3d0014;
            --mono:      'IBM Plex Mono', monospace;
            --sans:      'IBM Plex Sans', sans-serif;
        }
        body { background: var(--bg); color: var(--text); font-family: var(--sans); font-size: 14px; min-height: 100vh; }

        /* ── Header ── */
        header { border-bottom: 1px solid var(--border); padding: 0 40px; height: 56px; display: flex; align-items: center; justify-content: space-between; background: var(--surface); }
        .logo { font-family: var(--mono); font-size: 11px; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); text-decoration: none; }
        .header-right { display: flex; align-items: center; gap: 16px; }
        #clerk-user-button-nav { display: flex; align-items: center; }
        nav { display: flex; gap: 2px; }
        nav a { font-family: var(--mono); font-size: 11px; color: var(--muted); text-decoration: none; padding: 6px 12px; border-radius: 4px; letter-spacing: 0.06em; transition: color 0.15s, background 0.15s; }
        nav a:hover { color: var(--text); background: var(--border); }

        /* ── Layout ── */
        main { max-width: 860px; margin: 0 auto; padding: 40px 40px 80px; }

        /* ── Page header ── */
        .page-header { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 32px; padding-bottom: 20px; border-bottom: 1px solid var(--border); }
        .page-title { font-family: var(--mono); font-size: 22px; font-weight: 600; letter-spacing: -0.02em; color: var(--text); }
        .page-title small { display: block; font-size: 11px; font-weight: 400; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 4px; }

        /* ── Hero (signed out) ── */
        .hero { display: flex; flex-direction: column; align-items: flex-start; padding: 80px 0 60px; }
        .hero-label { font-family: var(--mono); font-size: 10px; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); margin-bottom: 20px; }
        .hero h1 { font-family: var(--mono); font-size: 36px; font-weight: 600; letter-spacing: -0.03em; color: var(--text); margin-bottom: 12px; }
        .hero p { font-size: 14px; color: var(--muted); margin-bottom: 32px; }
        .hero-signin { font-family: var(--mono); font-size: 12px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #000; background: var(--accent); padding: 10px 24px; border-radius: 4px; text-decoration: none; transition: opacity 0.15s; }
        .hero-signin:hover { opacity: 0.85; }

        /* ── Buttons ── */
        .btn { font-family: var(--mono); font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; border: none; border-radius: 4px; padding: 9px 18px; cursor: pointer; transition: opacity 0.15s, transform 0.1s; white-space: nowrap; text-decoration: none; display: inline-block; }
        .btn:hover { opacity: 0.85; }
        .btn:active { transform: scale(0.97); }
        .btn-ghost  { background: transparent; border: 1px solid var(--border-hi); color: var(--muted); }
        .btn-ghost:hover { border-color: var(--text); color: var(--text); opacity: 1; }
        .btn-danger { background: var(--danger-dim); border: 1px solid var(--danger); color: var(--danger); }

        /* ── Profile card ── */
        .profile-card { display: flex; gap: 28px; align-items: flex-start; background: var(--surface); border: 1px solid var(--border); border-radius: 6px; padding: 28px; margin-bottom: 24px; }
        .profile-avatar { flex-shrink: 0; }
        .profile-avatar img, .avatar-initials { width: 72px; height: 72px; border-radius: 50%; object-fit: cover; }
        .avatar-initials { display: flex; align-items: center; justify-content: center; background: var(--accent-dim); border: 1px solid var(--accent); color: var(--accent); font-family: var(--mono); font-size: 22px; font-weight: 600; }
        .profile-info { flex: 1; min-width: 0; }
        .profile-name { font-family: var(--mono); font-size: 16px; font-weight: 600; color: var(--text); margin-bottom: 4px; }
        .profile-email { font-size: 13px; color: var(--muted); margin-bottom: 2px; }
        .profile-username { font-family: var(--mono); font-size: 12px; color: var(--muted); margin-bottom: 20px; }
        .profile-meta { display: flex; flex-wrap: wrap; gap: 24px; }
        .meta-item { display: flex; flex-direction: column; gap: 4px; }
        .meta-label { font-family: var(--mono); font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted); }
        .meta-item code { font-family: var(--mono); font-size: 12px; color: var(--accent); background: var(--accent-dim); padding: 2px 8px; border-radius: 3px; }
        .meta-item span:not(.meta-label) { font-family: var(--mono); font-size: 12px; color: var(--text); }

        /* ── Dashboard content ── */
        .dashboard-content { background: var(--surface); border: 1px solid var(--border); border-radius: 6px; padding: 24px; }
        .panel-label { font-family: var(--mono); font-size: 10px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); margin-bottom: 12px; }
        .content-hint { font-size: 13px; color: var(--muted); }

        @media (max-width: 480px) { .profile-card { flex-direction: column; } }
    </style>
</head>
<body>
    <!-- Hide auth sections before Clerk loads to avoid flash -->
    <script>
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.clerk-signed-in, .clerk-signed-out')
            .forEach(function (el) { el.style.display = 'none'; });
    });
    </script>

    <header>
        <a class="logo" href="/">MarketData</a>
        <div class="header-right">
            <div class="clerk-signed-in">
                <nav>
                    <a href="/exchanges">Exchanges</a>
                    <a href="/currencies">Currencies</a>
                    <a href="/instruments">Instruments</a>
                    <a href="/equities">Equities</a>
                    <a href="/indexes">Indexes</a>
                    <a href="/option-contracts">Options</a>
                    <a href="/eod-prices">EOD Prices</a>
                    <a href="/option-eod-prices">Option Prices</a>
                    <a href="/corporate-actions">Corp Actions</a>
                </nav>
            </div>
            <div class="clerk-signed-in">
                <div id="clerk-user-button-nav"></div>
            </div>
        </div>
    </header>

    <main>
        <div class="dashboard">

            <!-- Signed out state -->
            <div class="clerk-signed-out">
                <div class="hero">
                    <div class="hero-label">Market Data</div>
                    <h1>Welcome back.</h1>
                    <p>Sign in to access the dashboard.</p>
                    <a class="hero-signin" href="/sign-in">Sign in →</a>
                </div>
            </div>

            <!-- Signed in state -->
            <div class="clerk-signed-in">

                <div class="page-header">
                    <div class="page-title">
                        dashboard
                        <small>account overview</small>
                    </div>
                    <button class="btn btn-danger" id="sign-out-btn">Sign out</button>
                </div>

                <div class="profile-card">
                    <div class="profile-avatar">
                        <img id="user-avatar" src="" alt="Profile photo" style="display:none" />
                        <div id="user-avatar-initials" class="avatar-initials"></div>
                    </div>
                    <div class="profile-info">
                        <div class="profile-name" id="user-full-name"></div>
                        <div class="profile-email" id="user-email"></div>
                        <div class="profile-username" id="user-username"></div>
                        <div class="profile-meta">
                            <div class="meta-item">
                                <span class="meta-label">User ID</span>
                                <code id="user-id"></code>
                            </div>
                            <div class="meta-item" id="org-section" style="display:none">
                                <span class="meta-label">Organisation</span>
                                <span id="user-org"></span>
                            </div>
                            <div class="meta-item">
                                <span class="meta-label">Member since</span>
                                <span id="user-created"></span>
                            </div>
                        </div>
                        <a class="btn btn-ghost" href="/profile" style="margin-top:20px">Edit profile</a>
                    </div>
                </div>

                <div class="dashboard-content">
                    <div class="panel-label">Application</div>
                    <p class="content-hint">Add your app content here.</p>
                </div>

            </div>
        </div>
    </main>

    <script>
    (async function () {
        await new Promise(function (resolve) {
            if (window.Clerk) { resolve(); return; }
            var t = setInterval(function () {
                if (window.Clerk) { clearInterval(t); resolve(); }
            }, 50);
        });

        await window.Clerk.load();

        var signedIn  = document.querySelectorAll('.clerk-signed-in');
        var signedOut = document.querySelectorAll('.clerk-signed-out');

        if (window.Clerk.user) {
            signedIn.forEach(function (el)  { el.style.display = ''; });
            signedOut.forEach(function (el) { el.style.display = 'none'; });

            var navBtn = document.getElementById('clerk-user-button-nav');
            if (navBtn) { window.Clerk.mountUserButton(navBtn); }

            var user = window.Clerk.user;

            // Avatar
            var img      = document.getElementById('user-avatar');
            var initials = document.getElementById('user-avatar-initials');
            if (user.imageUrl) {
                img.src = user.imageUrl;
                img.style.display = '';
                initials.style.display = 'none';
            } else {
                var first = (user.firstName || '').charAt(0).toUpperCase();
                var last  = (user.lastName  || '').charAt(0).toUpperCase();
                initials.textContent = first + last || '?';
            }

            // Name & email
            var fullName = [user.firstName, user.lastName].filter(Boolean).join(' ');
            document.getElementById('user-full-name').textContent = fullName || 'No name set';

            var primaryEmail = user.primaryEmailAddress;
            document.getElementById('user-email').textContent =
                primaryEmail ? primaryEmail.emailAddress : '';

            if (user.username) {
                document.getElementById('user-username').textContent = '@' + user.username;
            }

            document.getElementById('user-id').textContent = user.id;

            var org = window.Clerk.organization;
            if (org) {
                document.getElementById('user-org').textContent = org.name;
                document.getElementById('org-section').style.display = '';
            }

            if (user.createdAt) {
                document.getElementById('user-created').textContent =
                    new Date(user.createdAt).toLocaleDateString(undefined, {
                        year: 'numeric', month: 'long', day: 'numeric'
                    });
            }

            var btn = document.getElementById('sign-out-btn');
            if (btn) {
                btn.addEventListener('click', async function () {
                    await window.Clerk.signOut();
                    window.location.reload();
                });
            }
        } else {
            signedIn.forEach(function (el)  { el.style.display = 'none'; });
            signedOut.forEach(function (el) { el.style.display = ''; });
        }
    })();
    </script>
</body>
</html>
